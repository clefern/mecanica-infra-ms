# Copiar para .env e preencher antes de rodar docker-compose.full.yml
# .env não deve ser commitado (está no .gitignore)

# GitHub Personal Access Token com permissão read:packages
# Necessário para o Maven baixar mecanica-shared-kernel:0.1.0 do GitHub Packages durante o docker build
GITHUB_TOKEN=ghp_seu_token_aqui

# Banco de dados (padrões funcionam em dev local)
DB_USER=mecanica
DB_PASS=mecanica

# RabbitMQ (padrões do guest funcionam em dev local)
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
